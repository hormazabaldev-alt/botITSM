NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Do not expose in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional for direct schema administration.
POSTGRES_URL_NON_POOLING=

# ── Motor LLM primario: Anthropic (Claude) ────────────────────────────────────
# Recomendado. Habilita comprensión NLU real, tool calling y memoria conversacional.
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Motor LLM secundario: Mercury/Inception ──────────────────────────────────
# Se usa si ANTHROPIC_API_KEY no está configurado.
MERCURY_API_KEY=
MERCURY_BASE_URL=https://api.inceptionlabs.ai/v1
MERCURY_MODEL=mercury-2

# Prioridad: Anthropic → Mercury → Mock (reglas deterministicas sin LLM)
